# Database
DATABASE_URL="postgresql://user:password@localhost:5432/khadamaty_db"

# JWT
JWT_SECRET="your-super-secret-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Server
PORT=3001
NODE_ENV="development"
API_URL="http://localhost:3001"

# Frontend
WEB_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# Email (SendGrid)
SENDGRID_API_KEY=""
FROM_EMAIL="Nourmourad507@gmail.com"
FROM_NAME="خدماتي"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# Google Maps
GOOGLE_MAPS_API_KEY=""

# File Upload (AWS S3)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION=""

# Company Info (overrides config/company.js)
COMPANY_NAME="خدماتي"
