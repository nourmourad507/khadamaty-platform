{
  "name": "khadamaty-platform",
  "version": "1.0.0",
  "description": "منصة إدارة أعمال متكاملة - شركة خدماتي",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/database/prisma/schema.prisma",
    "db:seed": "node packages/database/prisma/seed.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prisma": "^5.15.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/khadamaty-platform.git"
  },
  "author": "خدماتي - Khadamaty",
  "license": "MIT"
}